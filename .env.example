GITHUB_TOKEN=ghp_your_token_here
ANTHROPIC_API_KEY=sk-ant-your-key-here
API_KEY=your-api-key-for-rest-auth

# Analyzer type: "api" (Anthropic Messages API) or "claudecode" (Claude Code CLI)
# ANALYZER_TYPE=api

# Claude Code analyzer settings (only used when ANALYZER_TYPE=claudecode)
# ANTHROPIC_API_KEY is not required when using claudecode mode
# GETH_REPO_PATH=./go-ethereum
# CLAUDE_CODE_MODEL=sonnet
# CLAUDE_CODE_MAX_BUDGET=0.50
# CLAUDE_CODE_TIMEOUT=5m

# Optional overrides (defaults shown)
# POLL_INTERVAL=4h
# BATCH_POLL_INTERVAL=5m
# LISTEN_ADDR=:8080
# DB_PATH=/data/geth-triage.db
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# BATCH_THRESHOLD=10
# MAX_DIFF_LINES=500
# LOG_LEVEL=info
