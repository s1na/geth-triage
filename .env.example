GITHUB_TOKEN=ghp_your_token_here
API_KEY=your-api-key-for-rest-auth

# Claude Code analyzer settings
# GETH_REPO_PATH=./go-ethereum
# CLAUDE_CODE_MODEL=sonnet
# CLAUDE_CODE_MAX_BUDGET=0.50
# CLAUDE_CODE_TIMEOUT=5m

# Usage threshold (0-100): pause when Claude session utilization exceeds this %
# USAGE_THRESHOLD=80

# Optional overrides (defaults shown)
# POLL_INTERVAL=1h
# LISTEN_ADDR=:8443
# HTTP_LISTEN_ADDR=:8080
# DB_PATH=/data/geth-triage.db
# LOG_LEVEL=info
